# Evitar travamento: timeout alto e menos retries longos
fetch-timeout=120000
fetch-retries=5
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000

# Garantir registro oficial (evitar proxy quebrado)
registry=https://registry.npmjs.org/

# Se ainda travar, descomente a linha abaixo para usar espelho (npmmirror):
# registry=https://registry.npmmirror.com/
